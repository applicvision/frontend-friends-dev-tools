{
  "name": "frontend-friends-extension",
  "displayName": "Frontend Friends",
  "description": "Syntax highlighting and diagnostics for Frontend Friends html tagged fragments.",
  "version": "1.0.0",
  "icon": "./icon.png",
  "engines": {
    "vscode": "^1.101.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/applicvision/frontend-friends-dev-tools.git"
  },
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "grammars": [
      {
        "injectTo": [
          "source.js",
          "source.ts",
          "text.html.basic"
        ],
        "scopeName": "ff-tagged-html",
        "path": "./syntaxes/ff-tagged-html.json",
        "embeddedLanguages": {
          "meta.embedded.block.html": "html",
          "meta.embedded.block.css": "css",
          "meta.embedded.block.svg": "xml"
        }
      },
      {
        "injectTo": [
          "source.js",
          "source.ts",
          "text.html.basic"
        ],
        "scopeName": "ff-template-substitution",
        "path": "./syntaxes/ff-template-substitution.json",
        "embeddedLanguages": {
          "meta.template.expression.ts": "typescript"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "diagnose": "diagnose-fragments",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "vscode-css-languageservice": "^6.3.8",
    "vscode-html-languageservice": "^5.6.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "@applicvision/frontend-friends-diagnostics": "latest"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.101.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  }
}
