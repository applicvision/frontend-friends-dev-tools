{
  "name": "frontend-friends-extension",
  "publisher": "ApplicVision",
  "displayName": "Frontend Friends",
  "description": "Syntax highlighting and diagnostics for Frontend Friends html tagged fragments.",
  "version": "1.0.0",
  "icon": "./icon.png",
  "engines": {
    "vscode": "^1.101.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/applicvision/frontend-friends-dev-tools.git"
  },
  "license": "MIT",
  "categories": [
    "Linters"
  ],
  "keywords": [
    "frontend",
    "diagnostics",
    "tagged",
    "template",
    "html"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "grammars": [
      {
        "injectTo": [
          "source.js",
          "source.ts",
          "text.html.basic"
        ],
        "scopeName": "ff-tagged-html",
        "path": "./syntaxes/ff-tagged-html.json",
        "embeddedLanguages": {
          "meta.embedded.block.html": "html",
          "meta.embedded.block.css": "css",
          "meta.embedded.block.svg": "xml"
        }
      },
      {
        "injectTo": [
          "source.js",
          "source.ts",
          "text.html.basic"
        ],
        "scopeName": "ff-template-substitution",
        "path": "./syntaxes/ff-template-substitution.json",
        "embeddedLanguages": {
          "meta.template.expression.ts": "typescript"
        }
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "@applicvision/frontend-friends-diagnostics": "latest",
    "vscode-css-languageservice": "^6.3.8",
    "vscode-html-languageservice": "^5.6.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "typescript": "^5.9.3",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.101.0",
    "@vscode/vsce": "^3.7.1"
  }
}
