{
	"injectionSelector": "L:source.js -comment -(string -meta.embedded), L:source.ts -comment -(string -meta.embedded)",
	"patterns": [
		{
			"name": "string.js.taggedTemplate.html",
			"contentName": "meta.embedded.block.html",
			"comment": "HTML Tagged template",
			"begin": "(html)\\s*`",
			"beginCaptures": {
				"1": {
					"name": "entity.name.function.tagged-template.ts"
				}
			},
			"end": "`",
			"endCaptures": {
				"0": {
					"name": "punctuation.definition.string.template.end.ts"
				}
			},
			"patterns": [
				{
					"include": "text.html.basic"
				},
				{
					"include": "source.ts#template-substitution-element"
				}
			]
		},
		{
			"name": "taggedTemplate.htmlWithKey",
			"contentName": "meta.embedded.block.html",
			"comment": "HTML Keyed Tagged template",
			"begin": "html\\.(key)\\(.+\\)\\s*(`)",
			"beginCaptures": {
				"1": {
					"name": "entity.name.function.tagged-template.ts"
				},
				"2": {
					"name": "string.ts"
				}
			},
			"end": "`",
			"endCaptures": {
				"0": {
					"name": "string.ts"
				}
			},
			"patterns": [
				{
					"include": "text.html.basic"
				},
				{
					"include": "source.ts#template-substitution-element"
				}
			]
		},
		{
			"name": "string.js.taggedTemplate.css",
			"contentName": "meta.embedded.block.css",
			"begin": "css\\s*`",
			"end": "`",
			"patterns": [
				{
					"include": "source.ts#template-substitution-element"
				},
				{
					"include": "source.css"
				}
			]
		},
		{
			"name": "string.js.taggedTemplate.svg",
			"contentName": "meta.embedded.block.svg",
			"begin": "(svg)\\s*`",
			"beginCaptures": {
				"1": {
					"name": "entity.name.function.tagged-template.ts"
				}
			},
			"end": "`",
			"patterns": [
				{
					"include": "text.xml"
				},
				{
					"include": "source.ts#template-substitution-element"
				}
			]
		},
		{
			"name": "taggedTemplate.svgWithKey",
			"contentName": "meta.embedded.block.svg",
			"begin": "svg\\.(key)\\(.+\\)\\s*(`)",
			"beginCaptures": {
				"1": {
					"name": "entity.name.function.tagged-template.js"
				},
				"2": {
					"name": "string.ts"
				}
			},
			"end": "`",
			"endCaptures": {
				"0": {
					"name": "string.ts"
				}
			},
			"patterns": [
				{
					"include": "text.xml"
				},
				{
					"include": "source.ts#template-substitution-element"
				}
			]
		}
	],
	"scopeName": "ff-tagged-html"
}
